#!/bin/sh
# A dmenu wrapper script for system functions.
case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case "$(printf "’ĆŻ lock\n’Īé log out\n’åĖ refresh dwm\n’ü╣ reboot\n’ć” shutdown" | dmenu -i -c -l 9)" in
	'’ĆŻ lock') gpg-connect-agent --no-autostart reloadagent /bye && xset dpms force off; slock ;;
	'’Īé log out') kill -TERM "$(pgrep -u "$USER" "\bdwm$")" ;;
	'’åĖ refresh dwm') kill -HUP "$(pgrep -u "$USER" "\bdwm$")" ;;
	'’ü╣ reboot') reboot ;;
	'’ć” shutdown') sudo -A poweroff ;;
	*) exit 1 ;;
esac
